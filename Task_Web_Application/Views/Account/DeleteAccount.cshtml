@{
    ViewData["Title"] = "Delete Account";
}

<div class="d-flex justify-content-center">
    <div class="card shadow-sm p-4 border-danger"
         style="width: 420px; border-radius: 14px;">

        <h5 class="text-danger text-center mb-3">
            ⚠ Delete Account
        </h5>

        <p class="text-muted text-center mb-4" style="font-size: 0.9rem;">
            This action is permanent and cannot be undone.
        </p>

        <form asp-action="DeleteAccount" method="post">
            @Html.AntiForgeryToken()

            <div class="mb-4">
                <label class="form-label">Confirm Password</label>
                <input type="password"
                       name="password"
                       class="form-control"
                       placeholder="Enter your password"
                       required />
            </div>

            <button type="submit" class="btn btn-danger w-100">
                Permanently Delete My Account
            </button>
        </form>

        @if (ViewBag.Error != null)
        {
            <div class="alert alert-danger mt-3 text-center">
                @ViewBag.Error
            </div>
        }
    </div>
</div>