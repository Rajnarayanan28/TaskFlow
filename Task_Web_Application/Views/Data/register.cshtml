@using Task_Web_Application.Models
@model RegisterModel
@{
    ViewData["Title"] = "register";
}

<!doctype html>
<html lang="en">
<head>
    <meta charset="utf-8">
    <title>Register</title>
    <meta name="viewport" content="width=device-width, initial-scale=1">
    <link href="https://fonts.googleapis.com/css2?family=DM+Sans:wght@300;400;500&family=DM+Serif+Display&display=swap" rel="stylesheet">

    <style>
        *, *::before, *::after {
            box-sizing: border-box;
            margin: 0;
            padding: 0;
        }

        body {
            background-color: #f7f5f2;
            font-family: 'DM Sans', sans-serif;
            font-weight: 300;
            color: #2c2c2c;
        }

        .card-wrapper {
            display: flex;
            justify-content: center;
            padding: 48px 24px;
        }

        .card {
            background: #ffffff;
            width: 100%;
            max-width: 420px;
            padding: 48px 44px;
            border-radius: 16px;
            box-shadow: 0 2px 24px rgba(0,0,0,0.06);
        }

        .card-header {
            margin-bottom: 32px;
        }

            .card-header h1 {
                font-family: 'DM Serif Display', serif;
                font-size: 1.9rem;
                font-weight: 400;
                color: #1a1a1a;
                margin-bottom: 6px;
            }

            .card-header p {
                font-size: 0.85rem;
                color: #9a9a9a;
            }

        .field {
            margin-bottom: 20px;
        }

        label {
            display: block;
            font-size: 0.78rem;
            font-weight: 500;
            color: #6b6b6b;
            margin-bottom: 7px;
            letter-spacing: 0.01em;
        }

        input, select {
            width: 100%;
            background: #f7f5f2;
            border: 1px solid transparent;
            border-radius: 8px;
            padding: 11px 14px;
            font-family: 'DM Sans', sans-serif;
            font-size: 0.88rem;
            font-weight: 300;
            color: #2c2c2c;
            outline: none;
            transition: border-color 0.2s, background 0.2s;
            appearance: none;
            -webkit-appearance: none;
        }

            input::placeholder {
                color: #c4c0bb;
            }

            input:focus, select:focus {
                background: #ffffff;
                border-color: #c8b89a;
            }

        .select-wrap {
            position: relative;
        }

            .select-wrap::after {
                content: '↓';
                position: absolute;
                right: 14px;
                top: 50%;
                transform: translateY(-50%);
                color: #b0aba4;
                font-size: 0.78rem;
                pointer-events: none;
            }

        .row {
            display: grid;
            grid-template-columns: 1fr 1fr;
            gap: 14px;
        }

        .check-row {
            display: flex;
            align-items: center;
            gap: 10px;
            margin-bottom: 28px;
        }

        input[type="checkbox"] {
            width: 16px;
            height: 16px;
            border-radius: 4px;
            border: 1.5px solid #d4cfc9;
            background: #f7f5f2;
            cursor: pointer;
            padding: 0;
            flex-shrink: 0;
            accent-color: #8a7560;
        }

        .check-row label {
            margin: 0;
            font-size: 0.78rem;
            color: #9a9a9a;
            font-weight: 300;
        }

        .check-row a {
            color: #8a7560;
            text-decoration: none;
        }

            .check-row a:hover {
                text-decoration: underline;
            }

        .btn {
            width: 100%;
            background: #2c2c2c;
            color: #f7f5f2;
            border: none;
            border-radius: 8px;
            padding: 13px;
            font-family: 'DM Sans', sans-serif;
            font-size: 0.88rem;
            font-weight: 400;
            letter-spacing: 0.02em;
            cursor: pointer;
            transition: background 0.2s;
        }

            .btn:hover {
                background: #444;
            }

        .footer-text {
            text-align: center;
            margin-top: 20px;
            font-size: 0.8rem;
            color: #b0aba4;
        }

            .footer-text a {
                color: #8a7560;
                text-decoration: none;
            }

                .footer-text a:hover {
                    text-decoration: underline;
                }

        .divider {
            height: 1px;
            background: #eeebe7;
            margin: 28px 0;
        }
    </style>
</head>
<body>

    <div class="card-wrapper">
        <div class="card">

            <div class="card-header">
                <h1>Create account</h1>
                <p>Fill in your details to get started</p>
            </div>

            <form method="post">

                <div class="row">
                    <div class="field">
                        <label>Username</label>
                        <input type="text" placeholder="e.g. johndoe" asp-for="Username">
                    </div>
                    <div class="field">
                        <label>Date of Birth</label>
                        <input type="date" asp-for="Dob">
                    </div>
                </div>

                <div class="field">
                    <label>Email Address</label>
                    <input type="email" placeholder="you@example.com" asp-for="Email">
                </div>

                <div class="field">
                    <label>Password</label>
                    <input type="password" placeholder="Create a password" asp-for="Password">
                </div>

                <div class="field">
                    <label>Account Type</label>
                    <div class="select-wrap">
                        <select asp-for="Type">
                            <option value="" disabled selected>Select a role</option>
                            <option value="admin">Admin</option>
                            <option value="user">User</option>
                        </select>
                    </div>
                </div>

                <div class="divider"></div>

               
                <div class="form-check mb-3">
                    <input class="form-check-input" type="checkbox">
                    <label class="form-check-label">
                        I agree to the Terms & Conditions
                    </label>
                </div>

                <input type="submit" class="btn" value="Sign Up" name="submit">

            </form>

            <p class="footer-text">
                Already have an account? <a asp-controller="data" asp-action="Login">Log in</a>
            </p>

        </div>
    </div>

</body>
</html>